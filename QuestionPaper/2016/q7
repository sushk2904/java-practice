import java.util.Scanner;


public class PalindromeCheck {
    public static void main(String[] args) {
        
        // BLOCK 1: INPUT COLLECTION
        // We initialize the Scanner to read from the standard input stream (keyboard).
        Scanner scanner = new Scanner(System.in);
        System.out.print("Enter a word: ");
        String original = scanner.nextLine();
        
        
        // BLOCK 2: THE REVERSAL LOGIC
        // Step A: Strings in Java are immutable (unchangeable). To flip the word, 
        // we "wrap" the string into a StringBuffer, which allows character manipulation.
        StringBuffer sb = new StringBuffer(original);
        
        // Step B: We call the built-in .reverse() method to flip the sequence.
        // Step C: We convert it back .toString() so it can be stored as a standard String.
        String reversed = sb.reverse().toString();
        
        
        // BLOCK 3: THE COMPARISON
        // We use .equalsIgnoreCase() to ensure 'A' matches 'a'.
        // This makes the check "case-insensitive," which is standard for palindromes.
        if (original.equalsIgnoreCase(reversed)) {
            System.out.println(original + " is a palindrome.");
        } else {
            System.out.println(original + " is NOT a palindrome.");
        }
        
        
        // BLOCK 4: CLEANUP
        // Closing the scanner releases the memory resources tied to the input stream.
        scanner.close();
    }
}