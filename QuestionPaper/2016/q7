public class CustomException extends Exception {
    
    // Constructor that passes the message to the parent Exception class
    public CustomException(String message) {
        super(message);
    }

    public static void main(String args[]) {
        // Let's test it with a CGPA that is too low
        double cgpa = 4.2; 
        
        try {
            // Check the promotion criteria
            if (cgpa < 4.5) {
                // Throw our custom exception if the condition is met
                throw new CustomException("Student cannot promote. CGPA is strictly less than 4.5");
            }
            
            // If the code reaches here, no exception was thrown
            System.out.println("Student successfully promoted to the next academic year!");
            
        } 
        catch (CustomException e) {
            // Catch and display our specific custom error
            System.out.println("PromotionFailedException: " + e.getMessage());
        } 
        catch (Exception e) {
            // It is always good practice to have a fallback catch block
            System.out.println("General Error: " + e.getMessage());
        }
    }
}



